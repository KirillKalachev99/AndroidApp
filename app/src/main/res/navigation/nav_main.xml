<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/feedFragment">

    <action
        android:id="@+id/action_global_postCommentsFragment"
        app:destination="@id/postCommentsFragment" />

    <fragment
        android:id="@+id/postCommentsFragment"
        android:name="com.example.ansteducation.fragment.PostCommentsFragment"
        android:label="post_comments_fragment"
        tools:layout="@layout/fragment_post_comments">
        <argument
            android:name="postId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.example.ansteducation.fragment.FeedFragment"
        android:label="fragment_feed"
        tools:layout="@layout/fragment_feed" >
        <action
            android:id="@+id/action_feedFragment_to_newPostFragment"
            app:destination="@id/newPostFragment" />
        <action
            android:id="@+id/action_feedFragment_to_singlePostFragment"
            app:destination="@id/singlePostFragment" />
        <action
            android:id="@+id/action_feedFragment_to_fullscreenImageFragment"
            app:destination="@id/fullscreenImageFragment" />
        <action
            android:id="@+id/action_feedFragment_to_authFragment"
            app:destination="@id/authFragment" />
    </fragment>

    <fragment
        android:id="@+id/newPostFragment"
        android:name="com.example.ansteducation.fragment.NewPostFragment"
        android:label="fragment_new_post"
        tools:layout="@layout/fragment_new_post" />

    <fragment
        android:id="@+id/authFragment"
        android:name="com.example.ansteducation.fragment.AuthFragment"
        android:label="auth_fragment"
        tools:layout="@layout/auth_fragment" />

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.ansteducation.fragment.RegisterFragment"
        android:label="register_fragment"
        tools:layout="@layout/fragment_register" />

    <fragment
        android:id="@+id/singlePostFragment"
        android:name="com.example.ansteducation.fragment.SinglePostFragment"
        android:label="SinglePostFragment" >
        <action
            android:id="@+id/action_singlePostFragment_to_newPostFragment"
            app:destination="@id/newPostFragment" />
        <action
            android:id="@+id/action_singlePostFragment_to_feedFragment"
            app:destination="@id/feedFragment" />
        <action
            android:id="@+id/action_singlePostFragment_to_fullscreenImageFragment"
            app:destination="@id/fullscreenImageFragment" />
        <action
            android:id="@+id/action_singlePostFragment_to_authFragment"
            app:destination="@id/authFragment" />
    </fragment>

    <fragment
        android:id="@+id/fullscreenImageFragment"
        android:name="com.example.ansteducation.fragment.FullscreenImageFragment"
        android:label="FullscreenImageFragment"
        tools:layout="@layout/fragment_fullscreen_image" />

    <fragment
        android:id="@+id/eventsFragment"
        android:name="com.example.ansteducation.fragment.EventsFragment"
        android:label="events_fragment"
        tools:layout="@layout/fragment_events" >
        <action
            android:id="@+id/action_eventsFragment_to_newEventFragment"
            app:destination="@id/newEventFragment" />
        <action
            android:id="@+id/action_eventsFragment_to_eventDetailFragment"
            app:destination="@id/eventDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/newEventFragment"
        android:name="com.example.ansteducation.fragment.NewEventFragment"
        android:label="fragment_new_event"
        tools:layout="@layout/fragment_new_event" >
        <argument
            android:name="eventId"
            android:defaultValue="0L"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/eventDetailFragment"
        android:name="com.example.ansteducation.fragment.EventDetailFragment"
        android:label="fragment_event_detail"
        tools:layout="@layout/fragment_event_detail" >
        <argument
            android:name="eventId"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/usersFragment"
        android:name="com.example.ansteducation.fragment.UsersFragment"
        android:label="users_fragment"
        tools:layout="@layout/fragment_users" />

    <fragment
        android:id="@+id/userProfileFragment"
        android:name="com.example.ansteducation.fragment.UserProfileFragment"
        android:label="user_profile_fragment"
        tools:layout="@layout/fragment_user_profile" >
        <argument
            android:name="userId"
            app:argType="long" />
        <argument
            android:name="userName"
            app:argType="string" />
        <argument
            android:name="userLogin"
            app:argType="string" />
    </fragment>
</navigation>